# Mobile env (Expo). EXPO_PUBLIC_ values are baked into the JS bundle at build time.
#
# Google iOS OAuth client id (Google Cloud Console → APIs & Services → Credentials
# → Create OAuth client ID → Application type: iOS, bundle id = app.kazka.ios).
# When empty the Google sign-in button is hidden in the app.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=1092595236581-d6p9vn0u8eoo5dbf8pkn737qmqcci90r.apps.googleusercontent.com
