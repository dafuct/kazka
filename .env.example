# Google Gemini — get a free key at https://aistudio.google.com/app/apikey
# Used for: text/storyteller, editor pass, scene extraction, moderation judge,
# AND Nano Banana image generation (gemini-2.5-flash-image).
GOOGLE_API_KEY=your_google_api_key_here

# Optional model overrides (defaults in application.yml).
#AI_TEXT_MODEL=gemini-2.5-flash
#AI_EDITOR_MODEL=gemini-2.5-flash
#AI_SCENE_MODEL=gemini-2.5-flash
#AI_NANO_BANANA_MODEL=gemini-2.5-flash-image
#MODERATION_MODEL=gemini-2.5-flash

# Optional base URL overrides.
#AI_TEXT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#AI_NANO_BANANA_BASE_URL=https://generativelanguage.googleapis.com/v1beta
#MODERATION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional sampling tuning.
#AI_TEXT_TEMPERATURE=0.75
#AI_TEXT_TOP_P=0.9
#AI_TEXT_MAX_TOKENS=4096
#AI_EDITOR_TEMPERATURE=0.3
#AI_EDITOR_TOP_P=0.9
#AI_EDITOR_MAX_TOKENS=4096

# Database
DB_URL=jdbc:mysql://mysql:3306/kazkar
DB_USER=kazkar
DB_PASS=kazkar

# Image storage backend: "filesystem" (default — local ./uploads dir, served at /uploads)
# or "r2" (private Cloudflare R2 bucket; the backend hands the browser short-lived presigned URLs).
STORAGE_PROVIDER=filesystem
# Cloudflare R2 — only required when STORAGE_PROVIDER=r2.
# R2 dashboard → create a bucket (keep it PRIVATE) → "Manage R2 API Tokens" → create an
# Access Key ID + Secret (Object Read & Write). Endpoint is shown as the S3 API endpoint.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=kazka-illustrations
# How long a presigned image link stays valid.
R2_PRESIGN_TTL=12h

# Auth — base URL the frontend is reachable at; used in email links.
# Local dev: Vite serves the SPA on :5173 and proxies /api to backend :8080.
APP_BASE_URL=http://localhost:5173

# JWT signing secret. Required (no default). Min 32 chars for HS256.
# Generate with: openssl rand -base64 48
KAZKA_JWT_SECRET=dev-only-secret-please-rotate-in-production-min-32-chars

# Google OAuth — Google Cloud Console → APIs & Services → Credentials → OAuth Client ID (Web application).
# Authorized redirect URI: ${APP_BASE_URL}/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP — easiest is a Gmail account with an app password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@kazka.local

# Seeded admin (created at startup if no user has this email)
ADMIN_EMAIL=admin@kazka.local
ADMIN_PASSWORD=change-me-please

# Set to true in HTTPS production environments
COOKIE_SECURE=false

# Google OAuth — iOS client id for mobile id-token verification.
# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
# → Application type: iOS, with bundle id matching mobile app: app.kazka.ios.
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Apple Services ID for web Sign in with Apple.
# Apple Developer → Identifiers → New Services ID; enable Sign in with Apple;
# Domains = kazkatales.com, Return URLs = https://kazkatales.com/auth/apple/callback.
APPLE_WEB_CLIENT_ID=

# Web frontend (Vite). VITE_-prefixed values are exposed at build time.
VITE_APPLE_WEB_CLIENT_ID=
VITE_APPLE_WEB_REDIRECT_URI=https://kazkatales.com/auth/apple/callback

# Billing — payment providers for the web subscription flow.
# Leave any provider's keys blank to disable that provider (a noop bean is wired in;
# calls to that provider's checkout will surface a clear "not configured" error).

# Paddle Billing — https://vendors.paddle.com → Developer tools → Authentication → API keys
# PADDLE_ENVIRONMENT is "sandbox" or "production". Webhook secret is from
# Developer tools → Notifications → Webhooks (notification signing secret, pdl_ntfset_...).
# Client-side token (VITE_PADDLE_CLIENT_TOKEN) is a separate token from
# Authentication → Client-side tokens — required to render the Paddle.js Checkout overlay.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_ENVIRONMENT=sandbox

# Monobank acquiring — https://www.monobank.ua/business merchant dashboard → API access.
# MONOBANK_WEBHOOK_PUBLIC_KEY is currently used as a shared-secret X-Sign header
# value (full ECDSA verification deferred — see docs/superpowers/SUBSCRIPTION-PROVIDER-SETUP.md).
# Tokenized recurring: first charge saves the card; the scheduled job pays-by-token monthly.
MONOBANK_TOKEN=
MONOBANK_WEBHOOK_PUBLIC_KEY=
MONOBANK_RECURRING_TICK=PT1H
MONOBANK_RECURRING_RETRIES=3
MONOBANK_RECURRING_PREFIX=renew-

# Where the user lands after checkout completes / is cancelled.
# Defaults work for local dev. In production, point at your real frontend host.
BILLING_SUCCESS_URL=http://localhost:5173/subscription/success
BILLING_CANCEL_URL=http://localhost:5173/pricing?cancelled=1
