{
  "name": "kazka",
  "private": true,
  "version": "0.1.0",
  "description": "Kazkar monorepo: backend (Spring Boot), frontend (React+Vite), mobile (Expo+RN), shared packages",
  "workspaces": [
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "gen:types": "bash scripts/gen-types.sh",
    "verify:types": "bash scripts/gen-types.sh && git diff --exit-code packages/shared/src/api-types.ts",
    "frontend:dev": "npm --workspace frontend run dev",
    "frontend:build": "npm --workspace frontend run build",
    "frontend:lint": "npm --workspace frontend run lint"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
